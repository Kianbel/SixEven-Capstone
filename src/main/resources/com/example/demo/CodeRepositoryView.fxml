<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" style="-fx-background-color: #1e1e1e;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.gui.CodeRepositoryController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
              style="-fx-background-color: #1e1e1e;">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <Label text="Code Snippets Repository" textFill="#dcdcdc"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;">
                    <font>
                        <Font name="Segoe UI Bold" size="18.0" />
                    </font>
                </Label>

                <HBox fillHeight="false" prefHeight="1.0" prefWidth="200.0">
                    <children>
                        <TextField fx:id="textfieldSearch" prefWidth="300.0" prefHeight="35.0"
                                   promptText="Search by title"
                                   style="-fx-prompt-text-fill: #858585; -fx-control-inner-background: #252526; -fx-text-fill: #dcdcdc; -fx-background-radius: 5; -fx-border-color: #3e3e42; -fx-border-radius: 5;" />
                    </children>
                </HBox>

                <Label fx:id="labelTotalSnippets" text="[total number] snippets" textFill="#858585">
                    <font>
                        <Font name="Segoe UI" size="12.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </Label>

                <TableView fx:id="tableRepository" prefWidth="0.0" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #252526; -fx-control-inner-background: #252526; -fx-border-color: #3e3e42; -fx-table-cell-border-color: #3e3e42;">
                    <columns>
                        <TableColumn fx:id="colTitle" prefWidth="425.0" text="Title"
                                     style="-fx-background-color: #2d2d30; -fx-text-fill: #dcdcdc;" />
                        <TableColumn fx:id="colLanguage" prefWidth="103.0" text="Language"
                                     style="-fx-background-color: #2d2d30; -fx-text-fill: #dcdcdc;" />
                        <TableColumn fx:id="colCreatedBy" prefWidth="161.0" text="Created by"
                                     style="-fx-background-color: #2d2d30; -fx-text-fill: #dcdcdc;" />
                        <TableColumn fx:id="colDateCreated" prefWidth="130.0" text="Date Created"
                                     style="-fx-background-color: #2d2d30; -fx-text-fill: #dcdcdc;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <Button mnemonicParsing="false" onAction="#onReturnToEditor"
                        text="➥ RETURN TO EDITOR"
                        prefHeight="40.0"
                        style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold;">
                    <font>
                        <Font name="Segoe UI Bold" size="13.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </Button>

            </children>
        </VBox>
    </children>
</AnchorPane>
