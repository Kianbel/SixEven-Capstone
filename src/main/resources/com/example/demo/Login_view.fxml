<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="650.0" prefWidth="450.0" style="-fx-background-color: #1e1e1e;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.gui.LoginController">
    <children>
        <VBox alignment="CENTER" maxWidth="380.0" spacing="25.0" style="-fx-background-color: #252526; -fx-background-radius: 10; -fx-border-color: #3e3e42; -fx-border-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 8);">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Welcome Back" textFill="#dcdcdc">
                            <font>
                                <Font name="Segoe UI Bold" size="28.0" />
                            </font>
                        </Label>
                        <Label text="Please log in to continue" textFill="#858585">
                            <font>
                                <Font name="Segoe UI" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox spacing="15.0">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Username" textFill="#858585">
                                    <font>
                                        <Font name="Segoe UI Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="textfieldUsername" prefHeight="40.0" promptText="Enter your username" style="-fx-prompt-text-fill: #858585; -fx-control-inner-background: #1e1e1e; -fx-text-fill: white; -fx-background-radius: 5; -fx-border-color: #3e3e42; -fx-border-radius: 5;" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Password" textFill="#858585">
                                    <font>
                                        <Font name="Segoe UI Bold" size="12.0" />
                                    </font>
                                </Label>
                                <PasswordField fx:id="textfieldPassword" prefHeight="40.0" promptText="Enter your password" style="-fx-prompt-text-fill: #858585; -fx-control-inner-background: #1e1e1e; -fx-text-fill: white; -fx-background-radius: 5; -fx-border-color: #3e3e42; -fx-border-radius: 5;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <Label fx:id="error" alignment="CENTER" maxWidth="1.7976931348623157E308" text="" textFill="#f44747" wrapText="true">
                    <font>
                        <Font name="Segoe UI" size="13.0" />
                    </font>
                </Label>

                <VBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="buttonLogIn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onLogInButtonClicked" prefHeight="45.0" style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Log In">
                            <font>
                                <Font name="Segoe UI Bold" size="16.0" />
                            </font>
                        </Button>
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Don't have an account?" textFill="#858585" />
                                <Hyperlink fx:id="hyperlinkRegister" onAction="#onRegisterHyperlinkClicked" style="-fx-text-fill: #007acc; -fx-underline: false;" text="Register" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>