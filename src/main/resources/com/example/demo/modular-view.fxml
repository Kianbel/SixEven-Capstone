<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #1e1e1e;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo.gui.ModularController">

    <left>
        <ScrollPane fitToWidth="true" style="-fx-background: #252526; -fx-border-color: transparent;">
            <VBox fx:id="toolbox" spacing="12"
                  style="-fx-padding: 15; -fx-background-color: #252526;">
                <Label text="🧩 BLOCKS TOOLBOX" textFill="#dcdcdc" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Separator style="-fx-background-color: #3e3e42;"/>
                <!-- Blocks will be added dynamically -->
            </VBox>
        </ScrollPane>
    </left>

    <center>
        <BorderPane>
            <top>
                <HBox spacing="15" style="-fx-padding: 10; -fx-background-color: #2d2d30;">
                    <Label text="Function:" textFill="#858585"/>
                    <TextField fx:id="functionNameField" text="myAlgorithm" prefWidth="150"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#onClear" text="Clear All" style="-fx-background-color: #d32f2f; -fx-text-fill: white;"/>
                </HBox>
            </top>
            <center>
                <ScrollPane fitToWidth="true" style="-fx-background: #1e1e1e;">
                    <VBox fx:id="workspace" spacing="15"
                          style="-fx-padding: 20; -fx-min-height: 600;"/>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>

    <right>
        <VBox prefWidth="450" spacing="10" style="-fx-padding: 10; -fx-background-color: #252526;">

            <!-- Parameters Section -->
            <VBox spacing="10" style="-fx-background-color: #2d2d30; -fx-background-radius: 8; -fx-padding: 12;">
                <Label text="🔧 Function Parameters" textFill="#dcdcdc" style="-fx-font-weight: bold;"/>

                <HBox spacing="10">
                    <TextField fx:id="newParameterField" promptText="param name"
                               style="-fx-background-color: #1e1e1e; -fx-text-fill: #dcdcdc; -fx-border-color: #3e3e42;"
                               HBox.hgrow="ALWAYS"/>
                    <Button fx:id="addParameterButton" text="Add"
                            style="-fx-background-color: #007acc; -fx-text-fill: white;"/>
                </HBox>

                <FlowPane fx:id="parametersContainer" hgap="8" vgap="8"
                          style="-fx-padding: 5 0 0 0;"/>

                <Separator style="-fx-background-color: #3e3e42;"/>
            </VBox>

            <!-- Output Section -->
            <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: #2d2d30; -fx-background-radius: 8; -fx-padding: 12;">
                <Label text="📄 OUTPUT" textFill="#dcdcdc" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="outputArea" editable="false" VBox.vgrow="ALWAYS" wrapText="true"
                          style="-fx-control-inner-background: #1e1e1e; -fx-text-fill: #4EC9B0; -fx-font-family: 'Consolas';"/>
            </VBox>

            <!-- Buttons -->
            <Button fx:id="calculateButton" onAction="#onCalculate" prefHeight="45"
                    style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-font-weight: bold;"
                    text="🚀 CALCULATE COMPLEXITY"/>
            <Button onAction="#onSave" prefHeight="35"
                    style="-fx-background-color: #2d8a39; -fx-text-fill: white;"
                    text="💾 SAVE TO DATABASE"/>
        </VBox>
    </right>
</BorderPane>