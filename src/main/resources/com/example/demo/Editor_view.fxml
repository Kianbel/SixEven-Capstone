<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #1e1e1e;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.gui.EditorController">

    <left>
        <ScrollPane fitToWidth="true" style="-fx-background: #252526; -fx-border-color: transparent;" vbarPolicy="NEVER">
            <VBox fx:id="toolbox" spacing="12" style="-fx-padding: 15; -fx-background-color: #252526;">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="🧩 BLOCKS TOOLBOX" textFill="#dcdcdc" />
                <Separator style="-fx-background-color: #3e3e42;" />
                <!-- Blocks will be added dynamically -->
            </VBox>
        </ScrollPane>
    </left>

    <center>
        <BorderPane>
            <top>
                <HBox spacing="15" style="-fx-padding: 10; -fx-background-color: #2d2d30;">
                    <Label text="Function:" textFill="#858585" />
                    <TextField fx:id="functionNameField" prefWidth="150" text="myAlgorithm" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#onClear" style="-fx-background-color: #d32f2f; -fx-text-fill: white;" text="Clear All" />
                </HBox>
            </top>
            <center>
                <ScrollPane fitToWidth="true" style="-fx-background: #1e1e1e;">
                    <VBox fx:id="workspace" spacing="15" style="-fx-padding: 20; -fx-min-height: 600;" />
                </ScrollPane>
            </center>
        </BorderPane>
    </center>

    <right>
        <VBox prefWidth="450" spacing="10" style="-fx-padding: 10; -fx-background-color: #252526;">

            <!-- Parameters Section -->
            <VBox spacing="10" style="-fx-background-color: #2d2d30; -fx-background-radius: 8; -fx-padding: 12;">
                <Label style="-fx-font-weight: bold;" text="🔧 Function Parameters" textFill="#dcdcdc" />

                <HBox spacing="10">
                    <TextField fx:id="newParameterField" promptText="Enter parameter name" style="-fx-background-color: #1e1e1e; -fx-text-fill: #dcdcdc; -fx-border-color: #3e3e42;" HBox.hgrow="ALWAYS" />
                    <Button fx:id="addParameterButton" style="-fx-background-color: #007acc; -fx-text-fill: white;" text="Add" />
                </HBox>

                <FlowPane fx:id="parametersContainer" hgap="8" style="-fx-padding: 5 0 0 0;" vgap="8" />

                <Separator style="-fx-background-color: #3e3e42;" />
            </VBox>

            <!-- Output Section -->
            <VBox spacing="10" style="-fx-background-color: #2d2d30; -fx-background-radius: 8; -fx-padding: 12;" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-weight: bold;" text="📄 OUTPUT" textFill="#dcdcdc" />
                <TextArea fx:id="outputArea" editable="false" style="-fx-control-inner-background: #1e1e1e; -fx-text-fill: #4EC9B0; -fx-font-family: 'Consolas';" wrapText="true" VBox.vgrow="ALWAYS" />
            </VBox>
         <HBox>
            <children>
      
                                    <!-- Buttons -->
                  <Button fx:id="calculateButton" maxWidth="1.7976931348623157E308" onAction="#onCalculate" prefHeight="45" style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-font-weight: bold;" text="🚀 CALCULATE COMPLEXITY" HBox.hgrow="ALWAYS" />
            </children>
         </HBox>
         <HBox spacing="30.0">
            <children>
                  <Button maxWidth="1.7976931348623157E308" onAction="#onSave" prefHeight="35.0" style="-fx-background-color: #2d8a39; -fx-text-fill: white;" text="💾 SAVE TO DATABASE" HBox.hgrow="ALWAYS" />
               <Button maxWidth="1.7976931348623157E308" onAction="#onGoToRepository" prefHeight="35.0" style="-fx-background-color: #2d8a39; -fx-text-fill: white;" text="&lt;/&gt; GO TO REPOSITORY" HBox.hgrow="ALWAYS" />
               <Button maxWidth="1.7976931348623157E308" onAction="#onLogout" prefHeight="35.0" style="-fx-background-color: #363636; -fx-text-fill: white; -fx-font-weight: bold;" text="➜] Logout" HBox.hgrow="ALWAYS" />
            </children>
         </HBox>
        </VBox>
    </right>
</BorderPane>
