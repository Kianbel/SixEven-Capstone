<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="550.0" prefWidth="750.0" style="-fx-background-color: #1e1e1e;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.gui.CodeDetailController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
              style="-fx-background-color: #1e1e1e;">
            <children>

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #2d2d30; -fx-border-color: #3e3e42; -fx-border-width: 0 0 1 0;">
                    <padding>
                        <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                    </padding>
                    <children>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Code Snippet Details" textFill="#dcdcdc">
                                    <font>
                                        <Font name="Segoe UI Bold" size="18.0" />
                                    </font>
                                </Label>
                                <Label text="Review the full code contents and related information below." textFill="#858585">
                                    <font>
                                        <Font name="Segoe UI" size="12.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Code Information -->
                <VBox spacing="10.0">
                    <padding>
                        <Insets left="25.0" right="25.0" />
                    </padding>
                    <children>
                        <Label text="Code Information" textFill="#dcdcdc">
                            <font>
                                <Font name="Segoe UI Bold" size="13.0" />
                            </font>
                        </Label>
                        <GridPane hgap="15.0" style="-fx-background-color: #252526; -fx-border-color: #3e3e42; -fx-border-radius: 6; -fx-background-radius: 6;" vgap="10.0">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER" minWidth="100.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="20.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="20.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="20.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="20.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label text="Title:" textFill="#858585" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <font><Font name="Segoe UI Bold" size="12.0" /></font>
                                </Label>
                                <Label fx:id="titleLabel" text="N/A" textFill="#dcdcdc" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Language:" textFill="#858585" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <font><Font name="Segoe UI Bold" size="12.0" /></font>
                                </Label>
                                <Label fx:id="languageLabel" text="N/A" textFill="#dcdcdc" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Date Created:" textFill="#858585" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <font><Font name="Segoe UI Bold" size="12.0" /></font>
                                </Label>
                                <Label fx:id="dateLabel" text="N/A" textFill="#dcdcdc" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Created By:" textFill="#858585" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                    <font><Font name="Segoe UI Bold" size="12.0" /></font>
                                </Label>
                                <Label fx:id="createdByLabel" text="N/A" textFill="#dcdcdc" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                            </children>
                        </GridPane>
                    </children>
                </VBox>

                <!-- Source Code -->
                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets left="25.0" right="25.0" />
                    </padding>
                    <children>
                        <Label text="Source Code:" textFill="#dcdcdc">
                            <font>
                                <Font name="Segoe UI Bold" size="13.0" />
                            </font>
                        </Label>
                        <TextArea fx:id="codeDetailsTextArea" editable="false"
                                  style="-fx-font-family: 'Consolas'; -fx-font-size: 13px; -fx-control-inner-background: #1e1e1e; -fx-border-color: #3e3e42;"
                                  wrapText="true" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <!-- Footer -->
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="25.0" top="5.0" />
                    </padding>
                    <children>
                        <Button mnemonicParsing="false" onAction="#onClick" prefWidth="110.0" prefHeight="35.0"
                                text="Close"
                                style="-fx-background-radius: 5; -fx-cursor: hand; -fx-background-color: #007acc; -fx-text-fill: white; -fx-font-weight: bold;">
                            <font><Font name="Segoe UI Bold" size="13.0" /></font>
                        </Button>
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
