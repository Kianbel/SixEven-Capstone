<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.gui.CodeRepositoryController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Code Snippets Repository" />
            <HBox fillHeight="false" prefHeight="1.0" prefWidth="200.0">
               <children>
                  <TextField fx:id="textfieldSearch" maxWidth="300.0" promptText="Filter by keywords" />
                  <Button fx:id="buttonSearch" mnemonicParsing="false" text="Search">
                     <HBox.margin>
                        <Insets left="20.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <Label fx:id="labelTotalSnippets" text="[total number] snippets">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>

                <TableView fx:id="tableRepository" prefWidth="0.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTitle" prefWidth="425.0" text="Title" />
                        <TableColumn fx:id="colLanguage" prefWidth="103.0" text="Language" />
                        <TableColumn fx:id="colCreatedBy" prefWidth="161.0" text="Created by" />
                        <TableColumn fx:id="colDateCreated" prefWidth="130.0" text="Date Created" />
                    </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
